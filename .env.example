PORT=8000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://admin:password@127.0.0.1:27018/one-million-checkboxes?authSource=admin

# Redis
REDIS_URL=redis://127.0.0.1:6379

# App JWT cookie/session token
JWT_SECRET=replace_with_a_long_random_secret

# OIDC / OAuth 2.0 authorization server
OIDC_ISSUER=http://localhost:8000
OIDC_CLIENT_ID=1m-checkboxes-client
OIDC_CLIENT_SECRET=replace_with_oidc_client_secret
OIDC_REDIRECT_URI=http://localhost:8000/api/auth/oidc/callback
